# Copy to .env and adjust before running.

# This password is for the SSH transport user named "bbs".
# The BBS app will still ask callers for their callsign/handle after login.
BBS_USER_PASSWORD=change-this-password

# Set true to let callers use "ssh bbs@host -p 2222" without a password.
# SSH still requires a username; use "bbs" as the shared transport user.
BBS_GUEST_MODE=false

BBS_NAME=HAMNET RADIO BBS
BBS_SYSOP=Sysop

# Comma-separated callsigns that should always be sysops.
# Example: BBS_SYSOPS=EA1ABC,DL1ABC
BBS_SYSOPS=

BBS_LOCATION=HamNet
BBS_WELCOME_TOPIC=Amateur radio notes, local nets, and packet-era experiments

# APRS-IS settings used by the APRS messaging screen.
APRS_IS_SERVER=rotate.aprs2.net
APRS_IS_PORT=14580
APRS_APP_NAME=HamNetBBS
APRS_APP_VERSION=0.1
